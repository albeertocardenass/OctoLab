FROM tleemcjr/metasploitable2

USER root

# Crear estructura básica del home de msfadmin
RUN mkdir -p /home/msfadmin/Desktop \
             /home/msfadmin/Documents \
             /home/msfadmin/Downloads \
             /home/msfadmin/Tools && \
    chown -R msfadmin:msfadmin /home/msfadmin

# Banner de bienvenida en /etc/motd
COPY motd.meta /etc/motd
RUN sed -i 's/\r//' /etc/motd

# Bash completo: .bashrc con prompt, aliases, historial y completion
COPY bashrc.meta /home/msfadmin/.bashrc
RUN sed -i 's/\r//' /home/msfadmin/.bashrc && \
    chown msfadmin:msfadmin /home/msfadmin/.bashrc

# Arrancar todos los servicios vulnerables al iniciar el contenedor
CMD ["/bin/bash", "-c", "/etc/init.d/ssh start 2>/dev/null; /etc/init.d/xinetd start 2>/dev/null; /etc/init.d/openbsd-inetd start 2>/dev/null; /etc/init.d/apache2 start 2>/dev/null; /etc/init.d/mysql start 2>/dev/null; exec /bin/bash"]
